{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agpprotocol.org/schema/agp.decision-context-1.schema.json",
  "title": "AGP Decision Context 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object_type",
    "context_id",
    "created_at",
    "expires_at",
    "policy",
    "proposal",
    "participants",
    "evidence",
    "constraints"
  ],
  "properties": {
    "object_type": {
      "const": "agp.decision-context/1"
    },
    "context_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "digest"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:/-]{1,127}[a-z0-9]$"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "payload"
      ],
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:/-]{1,127}[a-z0-9]$"
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "role",
          "weight"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._:/-]{1,127}[a-z0-9]$"
          },
          "role": {
            "enum": [
              "proposer",
              "voter",
              "reviewer",
              "approver",
              "observer"
            ]
          },
          "weight": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "digest",
          "media_type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._:/-]{1,127}[a-z0-9]$"
          },
          "digest": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "media_type": {
            "type": "string",
            "pattern": "^[a-z0-9!#$&^_.+-]+/[a-z0-9!#$&^_.+-]+$"
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "parameters"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._:/-]{1,127}[a-z0-9]$"
          },
          "kind": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._:/-]{1,127}[a-z0-9]$"
          },
          "parameters": {
            "type": "object"
          }
        }
      }
    }
  }
}
